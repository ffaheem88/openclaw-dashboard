# OpenClaw Dashboard Configuration
PORT=3000
SESSION_SECRET=change-me-to-a-random-string

# OpenClaw paths (auto-detected if standard install)
# OPENCLAW_HOME=~/.openclaw
# OPENCLAW_WORKSPACE=~/.openclaw/workspace

# VIS Database (optional — only needed for VIS integration)
# VIS_DB_HOST=db.example.com
# VIS_DB_PORT=1433
# VIS_DB_USER=readonly_user
# VIS_DB_PASS=your_password
# VIS_DB_NAME=your_database

# Agent name (determines session path: ~/.openclaw/agents/<name>/sessions/)
# Common values: voice, main
# OPENCLAW_AGENT=voice
